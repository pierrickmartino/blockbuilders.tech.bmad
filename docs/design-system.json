{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Blockbuilders Design System",
  "version": "3.0.0",
  "description": "Design system token inventory derived directly from frontend/src/app/globals.css and frontend/tailwind.config.ts — the authoritative runtime sources of truth. All color values are expressed as HSL triplets matching the CSS custom properties verbatim.",
  "sourceOfTruth": {
    "runtimeFiles": [
      "frontend/src/app/globals.css",
      "frontend/tailwind.config.ts"
    ],
    "documentCharacteristics": {
      "usesVariables": true,
      "format": "HSL triplets matching CSS custom property declarations",
      "purpose": "Documentation mirror of the runtime token set; keep in sync with globals.css"
    },
    "syncRule": "globals.css is the golden source. Update this JSON to mirror it — never the reverse. When globals.css changes, regenerate or manually sync this file."
  },
  "themeConfiguration": {
    "supportedThemes": [
      "light",
      "dark"
    ],
    "defaultTheme": "light",
    "themeParity": "Both themes share the same structure, spacing, and component geometry with different fills, text colors, and semantic brightness. CSS class `.dark` applied to the `<html>` element activates the dark variant.",
    "documentedResponsiveBehavior": true
  },
  "tokens": {
    "colors": {
      "note": "All values are HSL triplets as declared in globals.css :root / .dark. Use hsl(var(--token-name)) in Tailwind / CSS.",
      "surfaces": {
        "background": {
          "cssVar": "--background",
          "light": "0 0% 100%",
          "dark": "240 8% 5%"
        },
        "foreground": {
          "cssVar": "--foreground",
          "light": "0 0% 4%",
          "dark": "240 5% 92%"
        },
        "surfaceBase": {
          "cssVar": "--surface-base",
          "light": "0 0% 100%",
          "dark": "240 8% 5%"
        },
        "surfaceElevated": {
          "cssVar": "--surface-elevated",
          "light": "220 14% 96%",
          "dark": "240 6% 9%"
        },
        "surfaceOverlay": {
          "cssVar": "--surface-overlay",
          "light": "0 0% 100%",
          "dark": "240 4% 11%"
        },
        "card": {
          "cssVar": "--card",
          "light": "0 0% 100%",
          "dark": "240 8% 5%"
        },
        "cardForeground": {
          "cssVar": "--card-foreground",
          "light": "0 0% 4%",
          "dark": "240 5% 92%"
        },
        "popover": {
          "cssVar": "--popover",
          "light": "0 0% 100%",
          "dark": "240 4% 9%"
        },
        "popoverForeground": {
          "cssVar": "--popover-foreground",
          "light": "0 0% 4%",
          "dark": "240 5% 92%"
        }
      },
      "brand": {
        "primary": {
          "cssVar": "--primary",
          "note": "Darkened from 204 65% 57% to 204 75% 40% in light mode to meet WCAG 2.2 AA contrast (≥4.5:1 vs white).",
          "light": "204 75% 40%",
          "dark": "204 76% 63%"
        },
        "primaryForeground": {
          "cssVar": "--primary-foreground",
          "light": "0 0% 100%",
          "dark": "240 8% 5%"
        },
        "secondary": {
          "cssVar": "--secondary",
          "light": "220 23% 97%",
          "dark": "240 4% 9%"
        },
        "secondaryForeground": {
          "cssVar": "--secondary-foreground",
          "light": "0 0% 4%",
          "dark": "240 5% 92%"
        },
        "muted": {
          "cssVar": "--muted",
          "light": "220 23% 97%",
          "dark": "240 4% 9%"
        },
        "mutedForeground": {
          "cssVar": "--muted-foreground",
          "light": "0 0% 40%",
          "dark": "240 3% 62%"
        },
        "textSubtle": {
          "cssVar": "--text-subtle",
          "light": "0 0% 38%",
          "dark": "240 3% 55%"
        },
        "accent": {
          "cssVar": "--accent",
          "note": "Intentionally ~4% lighter than secondary/muted so bg-secondary hover:bg-accent produces perceptible hover feedback.",
          "light": "220 14% 93%",
          "dark": "240 4% 13%"
        },
        "accentForeground": {
          "cssVar": "--accent-foreground",
          "light": "0 0% 4%",
          "dark": "240 5% 92%"
        }
      },
      "state": {
        "destructive": {
          "cssVar": "--destructive",
          "light": "0 72% 51%",
          "dark": "0 84% 60%"
        },
        "destructiveForeground": {
          "cssVar": "--destructive-foreground",
          "light": "0 0% 100%",
          "dark": "240 5% 92%"
        },
        "destructiveSoft": {
          "cssVar": "--destructive-soft",
          "light": "0 84% 96%",
          "dark": "0 55% 14%"
        },
        "success": {
          "cssVar": "--success",
          "light": "142 76% 36%",
          "dark": "142 71% 45%"
        },
        "successForeground": {
          "cssVar": "--success-foreground",
          "light": "0 0% 4%",
          "dark": "240 8% 5%"
        },
        "successSoft": {
          "cssVar": "--success-soft",
          "light": "142 70% 94%",
          "dark": "142 50% 12%"
        },
        "warning": {
          "cssVar": "--warning",
          "light": "38 92% 50%",
          "dark": "43 96% 56%"
        },
        "warningForeground": {
          "cssVar": "--warning-foreground",
          "light": "0 0% 4%",
          "dark": "240 8% 5%"
        },
        "warningSoft": {
          "cssVar": "--warning-soft",
          "light": "38 92% 94%",
          "dark": "38 60% 14%"
        },
        "info": {
          "cssVar": "--info",
          "note": "Intentionally distinct from --primary (sky-blue vs teal-blue) so informational banners and primary action buttons are visually separable.",
          "light": "210 80% 45%",
          "dark": "210 76% 68%"
        },
        "infoForeground": {
          "cssVar": "--info-foreground",
          "light": "0 0% 100%",
          "dark": "240 8% 5%"
        },
        "infoSoft": {
          "cssVar": "--info-soft",
          "light": "210 80% 95%",
          "dark": "210 60% 14%"
        }
      },
      "borders": {
        "border": {
          "cssVar": "--border",
          "light": "210 13% 94%",
          "dark": "240 5% 17%"
        },
        "input": {
          "cssVar": "--input",
          "light": "210 13% 94%",
          "dark": "240 5% 17%"
        },
        "ring": {
          "cssVar": "--ring",
          "light": "204 75% 40%",
          "dark": "204 76% 63%"
        },
        "focusRing": {
          "cssVar": "--focus-ring",
          "note": "Dedicated alias of --ring so a11y can tune it independently of --primary.",
          "light": "204 75% 40%",
          "dark": "204 76% 63%"
        }
      },
      "charts": {
        "chart1": {
          "cssVar": "--chart-1",
          "light": "204 75% 40%",
          "dark": "204 76% 63%"
        },
        "chart2": {
          "cssVar": "--chart-2",
          "light": "142 76% 36%",
          "dark": "142 71% 45%"
        },
        "chart3": {
          "cssVar": "--chart-3",
          "light": "38 92% 50%",
          "dark": "43 96% 56%"
        },
        "chart4": {
          "cssVar": "--chart-4",
          "light": "204 66% 72%",
          "dark": "204 51% 21%"
        },
        "chart5": {
          "cssVar": "--chart-5",
          "light": "0 72% 51%",
          "dark": "0 84% 60%"
        }
      },
      "canvasNodes": {
        "note": "CSS vars promoted in Phase 3 so canvas node colors track the token system. Tint variants are derived at 10%/20% alpha via Tailwind opacity modifiers (bg-[hsl(var(--canvas-node-input)/0.1)]).",
        "input": {
          "cssVar": "--canvas-node-input",
          "light": "271 81% 56%",
          "dark": "271 81% 65%"
        },
        "indicator": {
          "cssVar": "--canvas-node-indicator",
          "light": "217 91% 60%",
          "dark": "217 91% 68%"
        },
        "logic": {
          "cssVar": "--canvas-node-logic",
          "light": "32 95% 44%",
          "dark": "32 95% 55%"
        },
        "signal": {
          "cssVar": "--canvas-node-signal",
          "light": "142 71% 45%",
          "dark": "142 71% 55%"
        },
        "risk": {
          "cssVar": "--canvas-node-risk",
          "light": "0 72% 51%",
          "dark": "0 84% 60%"
        }
      },
      "sidebar": {
        "sidebarBackground": {
          "cssVar": "--sidebar-background",
          "light": "220 23% 97%",
          "dark": "240 4% 9%"
        },
        "sidebarForeground": {
          "cssVar": "--sidebar-foreground",
          "light": "0 0% 4%",
          "dark": "240 5% 92%"
        },
        "sidebarPrimary": {
          "cssVar": "--sidebar-primary",
          "light": "204 75% 40%",
          "dark": "204 76% 63%"
        },
        "sidebarPrimaryForeground": {
          "cssVar": "--sidebar-primary-foreground",
          "light": "0 0% 100%",
          "dark": "240 8% 5%"
        },
        "sidebarAccent": {
          "cssVar": "--sidebar-accent",
          "light": "210 13% 94%",
          "dark": "240 5% 17%"
        },
        "sidebarAccentForeground": {
          "cssVar": "--sidebar-accent-foreground",
          "light": "0 0% 4%",
          "dark": "240 5% 92%"
        },
        "sidebarBorder": {
          "cssVar": "--sidebar-border",
          "light": "210 13% 94%",
          "dark": "240 5% 17%"
        },
        "sidebarRing": {
          "cssVar": "--sidebar-ring",
          "light": "204 75% 40%",
          "dark": "204 76% 63%"
        }
      }
    },
    "typography": {
      "fontFamily": {
        "sans": "IBM Plex Sans",
        "mono": "IBM Plex Mono"
      },
      "fontWeight": {
        "normal": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "typeScale": {
        "eyebrow12": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 12,
          "fontWeight": 600,
          "letterSpacing": 1
        },
        "hero56": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 56,
          "fontWeight": 700,
          "letterSpacing": -1.5
        },
        "display48": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 48,
          "fontWeight": 700,
          "letterSpacing": -1.5
        },
        "section24": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 24,
          "fontWeight": 600,
          "letterSpacing": -0.5
        },
        "cardTitle18": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 18,
          "fontWeight": 600,
          "letterSpacing": -0.3
        },
        "body16": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 16,
          "fontWeight": 400,
          "lineHeight": 1.6
        },
        "body15": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 15,
          "fontWeight": 400
        },
        "ui14": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 14,
          "fontWeight": 400
        },
        "label13Medium": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 13,
          "fontWeight": 500
        },
        "label13Semibold": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 13,
          "fontWeight": 600
        },
        "badge12Medium": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 12,
          "fontWeight": 500
        },
        "badge12Semibold": {
          "fontFamily": "IBM Plex Sans",
          "fontSize": 12,
          "fontWeight": 600
        },
        "data12Mono": {
          "fontFamily": "IBM Plex Mono",
          "fontSize": 12,
          "fontWeight": 400
        },
        "caption11Mono": {
          "fontFamily": "IBM Plex Mono",
          "fontSize": 11,
          "fontWeight": 400
        },
        "metric32Mono": {
          "fontFamily": "IBM Plex Mono",
          "fontSize": 32,
          "fontWeight": 700
        }
      }
    },
    "spacing": {
      "note": "4px base grid. Values in pixels unless flagged as clamp().",
      "0": 0,
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "6": 24,
      "8": 32,
      "10": 40,
      "12": 48,
      "14": 56,
      "16": 64,
      "20": 80,
      "24": 96,
      "32": 128,
      "section": {
        "cssVar": "--space-section",
        "value": "clamp(3rem, 2.4rem + 3vw, 6rem)",
        "tailwindUtility": "py-section",
        "note": "Canonical between-major-sections vertical rhythm"
      },
      "sectionTight": {
        "cssVar": "--space-section-tight",
        "value": "clamp(1.5rem, 1.2rem + 1.5vw, 3rem)",
        "tailwindUtility": "py-section-tight",
        "note": "Compact stacks: in-card sections, sub-sections"
      }
    },
    "radius": {
      "cssVar": "--radius",
      "note": "--radius is 0.5rem (8px). Tailwind config extends radius.default to var(--radius). Derived sizes: sm = calc(var(--radius) - 4px), md = calc(var(--radius) - 2px), lg = var(--radius), xl = calc(var(--radius) + 4px).",
      "checkbox": 3,
      "default": 8,
      "md": 6,
      "lg": 8,
      "xl": 12,
      "full": 9999
    },
    "borders": {
      "default": 1,
      "emphasis": 2
    },
    "shadows": {
      "note": "Three-stop shadow scale backed by CSS vars. Values use --foreground so they automatically invert in dark mode.",
      "sm": {
        "cssVar": "--shadow-sm",
        "value": "0 1px 2px 0 hsl(var(--foreground) / 0.05)",
        "tailwindClass": "shadow-sm",
        "usage": "Subtle lift for inline elements, small pills"
      },
      "md": {
        "cssVar": "--shadow-md",
        "value": "0 4px 6px -1px hsl(var(--foreground) / 0.08), 0 2px 4px -2px hsl(var(--foreground) / 0.05)",
        "tailwindClass": "shadow-md",
        "usage": "Cards, dropdowns, popovers"
      },
      "overlay": {
        "cssVar": "--shadow-overlay",
        "value": "0 20px 25px -5px hsl(var(--foreground) / 0.12), 0 8px 10px -6px hsl(var(--foreground) / 0.08)",
        "tailwindClass": "shadow-overlay",
        "usage": "Modals, command palettes, sheets"
      }
    },
    "motion": {
      "note": "Motion tokens replace inline duration-150/200/300 classes. Use Tailwind utilities duration-fast, duration-normal, ease-default defined in tailwind.config.ts.",
      "durationFast": {
        "cssVar": "--duration-fast",
        "value": "150ms",
        "tailwindClass": "duration-fast",
        "usage": "Clicks, toggles, hover reveals"
      },
      "durationNormal": {
        "cssVar": "--duration-normal",
        "value": "250ms",
        "tailwindClass": "duration-normal",
        "usage": "Modals, drawers, page-level reveals"
      },
      "easeDefault": {
        "cssVar": "--ease-default",
        "value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "tailwindClass": "ease-default",
        "note": "Ease-out-expo curve: quick settle, no overshoot"
      }
    },
    "iconSizes": {
      "sm": 14,
      "md": 16,
      "lg": 20,
      "xl": 24
    },
    "sizing": {
      "button": {
        "smallHeight": 32,
        "defaultHeight": 36,
        "largeHeight": 40,
        "iconSize": 36
      },
      "input": {
        "height": 36
      },
      "header": {
        "height": 56
      },
      "checkbox": {
        "box": 16
      },
      "sidebar": {
        "width": 260
      },
      "statePanel": {
        "height": 200
      },
      "spinner": {
        "size": 32,
        "stroke": 2
      }
    }
  },
  "components": {
    "button": {
      "base": {
        "radius": 8,
        "height": 36,
        "gap": 8,
        "horizontalPadding": 16,
        "font": "label13Semibold or label13Medium depending on emphasis"
      },
      "variants": {
        "primary": {
          "light": {
            "fill": "hsl(var(--primary))",
            "text": "hsl(var(--primary-foreground))"
          },
          "dark": {
            "fill": "hsl(var(--primary))",
            "text": "hsl(var(--primary-foreground))"
          }
        },
        "secondary": {
          "light": {
            "fill": "hsl(var(--secondary))",
            "text": "hsl(var(--secondary-foreground))"
          },
          "dark": {
            "fill": "hsl(var(--secondary))",
            "text": "hsl(var(--secondary-foreground))"
          }
        },
        "outline": {
          "light": {
            "border": "hsl(var(--border))",
            "text": "hsl(var(--foreground))"
          },
          "dark": {
            "border": "hsl(var(--border))",
            "text": "hsl(var(--foreground))"
          }
        },
        "ghost": {
          "light": {
            "text": "hsl(var(--muted-foreground))"
          },
          "dark": {
            "text": "hsl(var(--muted-foreground))"
          }
        },
        "destructive": {
          "light": {
            "fill": "hsl(var(--destructive-soft))",
            "border": "hsl(var(--destructive) / 0.2)",
            "text": "hsl(var(--destructive))"
          },
          "dark": {
            "fill": "hsl(var(--destructive-soft))",
            "border": "hsl(var(--destructive) / 0.3)",
            "text": "hsl(var(--destructive))"
          }
        }
      },
      "sizes": {
        "small": {
          "height": 32,
          "horizontalPadding": 12,
          "textSize": 12
        },
        "default": {
          "height": 36,
          "horizontalPadding": 16,
          "textSize": 13
        },
        "large": {
          "height": 40,
          "horizontalPadding": 20,
          "textSize": 14
        },
        "icon": {
          "width": 36,
          "height": 36,
          "iconSize": 16
        }
      }
    },
    "input": {
      "stack": {
        "labelGap": 6
      },
      "label": {
        "font": "label13Medium",
        "light": {
          "text": "hsl(var(--foreground))"
        },
        "dark": {
          "text": "hsl(var(--foreground))"
        }
      },
      "field": {
        "height": 36,
        "radius": 8,
        "horizontalPadding": 12,
        "light": {
          "defaultBorder": "hsl(var(--border))",
          "activeBorder": "hsl(var(--focus-ring))",
          "surface": "hsl(var(--background))",
          "placeholder": "hsl(var(--muted-foreground) / 0.53)"
        },
        "dark": {
          "defaultBorder": "hsl(var(--border))",
          "activeBorder": "hsl(var(--focus-ring))",
          "surface": "hsl(var(--surface-elevated))",
          "placeholder": "hsl(var(--muted-foreground) / 0.53)"
        }
      }
    },
    "tabs": {
      "container": {
        "height": 36,
        "radius": 8,
        "padding": 2,
        "light": {
          "fill": "hsl(var(--surface-elevated))"
        },
        "dark": {
          "fill": "hsl(var(--surface-elevated))"
        }
      },
      "tab": {
        "radius": 6,
        "horizontalPadding": 14,
        "font": "label13Medium"
      },
      "active": {
        "light": {
          "fill": "hsl(var(--background))",
          "text": "hsl(var(--foreground))",
          "shadow": "sm"
        },
        "dark": {
          "fill": "hsl(var(--surface-overlay))",
          "text": "hsl(var(--foreground))",
          "shadow": "sm"
        }
      },
      "inactive": {
        "light": {
          "text": "hsl(var(--muted-foreground))"
        },
        "dark": {
          "text": "hsl(var(--muted-foreground))"
        }
      }
    },
    "card": {
      "default": {
        "radius": 8,
        "border": {
          "light": "hsl(var(--border))",
          "dark": "hsl(var(--border))"
        },
        "surface": {
          "light": "hsl(var(--card))",
          "dark": "hsl(var(--card))"
        },
        "shadow": "sm",
        "headerPadding": 24,
        "bodyPadding": [0, 24, 24, 24],
        "footerPadding": [16, 24],
        "footerGap": 12
      },
      "headerText": {
        "title": "cardTitle18",
        "description": "ui14"
      },
      "contentText": {
        "body": "ui14",
        "bodyColor": {
          "light": "hsl(var(--muted-foreground))",
          "dark": "hsl(var(--muted-foreground))"
        }
      }
    },
    "badge": {
      "variants": {
        "default": {
          "light": {
            "fill": "hsl(var(--primary))",
            "text": "hsl(var(--primary-foreground))"
          },
          "dark": {
            "fill": "hsl(var(--primary))",
            "text": "hsl(var(--primary-foreground))"
          }
        },
        "secondary": {
          "light": {
            "fill": "hsl(var(--secondary))",
            "text": "hsl(var(--secondary-foreground))"
          },
          "dark": {
            "fill": "hsl(var(--secondary))",
            "text": "hsl(var(--secondary-foreground))"
          }
        },
        "destructive": {
          "light": {
            "fill": "hsl(var(--destructive))",
            "text": "hsl(var(--destructive-foreground))"
          },
          "dark": {
            "fill": "hsl(var(--destructive))",
            "text": "hsl(var(--destructive-foreground))"
          }
        },
        "outline": {
          "light": {
            "border": "hsl(var(--border))",
            "text": "hsl(var(--foreground))"
          },
          "dark": {
            "border": "hsl(var(--border))",
            "text": "hsl(var(--foreground))"
          }
        }
      },
      "statusStyle": {
        "radius": 4,
        "padding": [3, 10],
        "gap": 6,
        "dot": 6
      }
    },
    "alert": {
      "base": {
        "radius": 8,
        "padding": [10, 14],
        "gap": 10,
        "icon": 16,
        "font": "label13Medium"
      },
      "variants": {
        "success": {
          "light": {
            "fill": "hsl(var(--success-soft))",
            "border": "hsl(var(--success) / 0.2)",
            "text": "hsl(var(--success))"
          },
          "dark": {
            "fill": "hsl(var(--success-soft))",
            "border": "hsl(var(--success) / 0.3)",
            "text": "hsl(var(--success))"
          }
        },
        "destructive": {
          "light": {
            "fill": "hsl(var(--destructive-soft))",
            "border": "hsl(var(--destructive) / 0.2)",
            "text": "hsl(var(--destructive))"
          },
          "dark": {
            "fill": "hsl(var(--destructive-soft))",
            "border": "hsl(var(--destructive) / 0.3)",
            "text": "hsl(var(--destructive))"
          }
        },
        "warning": {
          "light": {
            "fill": "hsl(var(--warning-soft))",
            "border": "hsl(var(--warning) / 0.2)",
            "text": "hsl(var(--warning))"
          },
          "dark": {
            "fill": "hsl(var(--warning-soft))",
            "border": "hsl(var(--warning) / 0.3)",
            "text": "hsl(var(--warning))"
          }
        },
        "info": {
          "light": {
