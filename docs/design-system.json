      "compact": 14,
      "default": 16,
      "chrome": 20,
      "state": 24
    },
    "guidance": [
      "Icons remain monochrome or semantic-color only",
      "Use aria-hidden on decorative icons; provide aria-label or visually-hidden text for meaningful icons",
      "Prefer SVG icons over emoji in UI components"
    ]
  },
  "accessibility": {
    "wcag": "2.2 AA",
    "colorContrast": {
      "normalText": "≥4.5:1",
      "largeText": "≥3:1",
      "uiComponents": "≥3:1"
    },
    "landmarks": {
      "main": "<main id=\"main-content\">",
      "nav": "<nav aria-label=\"Main navigation\">",
      "sidebar": "<aside>"
    },
    "focusRing": "focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1",
    "reducedMotion": "Handled globally in globals.css via prefers-reduced-motion; per-component motion-reduce: overrides available."
  },
  "utilities": {
    "surfaceRecipes": {
      "card": {
        "fill": "hsl(var(--card))",
        "border": "hsl(var(--border))",
        "shadow": "shadow-sm"
      },
      "elevated": {
        "fill": "hsl(var(--surface-elevated))",
        "border": "hsl(var(--border))"
      },
      "overlay": {
        "fill": "hsl(var(--surface-overlay))",
        "shadow": "shadow-overlay"
      }
    },
    "textRecipes": {
      "primary": "hsl(var(--foreground))",
      "muted": "hsl(var(--muted-foreground))",
      "subtle": "hsl(var(--text-subtle))",
      "monoData": "font-mono tabular-nums tracking-tight (via .data-text utility)"
    },
    "divider": {
      "light": "hsl(var(--border))",
      "dark": "hsl(var(--border))",
      "thickness": 1
    }
  },
  "guidelines": {
    "do": [
      "Use IBM Plex Sans and IBM Plex Mono as the type system",
      "Use --primary (teal-blue) for primary actions and interactive chrome",
      "Use --info (sky-blue, 210°) for informational banners — it is intentionally distinct from --primary (204°)",
      "Reserve --success, --destructive, and --warning for outcome and risk semantics",
      "Reference CSS custom properties (hsl(var(--token-name))) rather than hardcoding hex or HSL literals in component code",
      "Use shadow-sm for cards/dropdowns, shadow-md for elevated panels, shadow-overlay for modals",
      "Use duration-fast (150ms) for clicks/toggles and duration-normal (250ms) for modals and drawers",
      "Keep --radius-based corners: default 8px, checkbox 3px, full = pill/circle",
      "Use solid fills and thin 1px borders; avoid gradient-heavy surfaces",
      "Follow WCAG 2.2 AA: focus-visible rings, landmark elements, aria-label on interactive icons"
    ],
    "dont": [
      "Do not hardcode hex or raw HSL values in component code — reference the CSS var instead",
      "Do not introduce glassmorphism, blur-heavy panels, or gradient headlines",
      "Do not skip aria-label on icon-only buttons or interactive elements",
      "Do not use --primary color for informational banners — use --info to keep action and information visually separable",
      "Do not use inline duration-150/200/300 Tailwind classes — use duration-fast / duration-normal tokens instead"
    ],
    "implementationNotes": [
      "globals.css is the single runtime source of truth. This JSON is a documentation mirror.",
      "tailwind.config.ts extends Tailwind with shadow-sm/md/overlay, duration-fast/normal, ease-default, and py-section/section-tight utilities.",
      "Canvas nodes use --canvas-node-{category} CSS vars for their accent colors. Tints are derived at runtime via Tailwind opacity modifiers.",
      "Dark mode is activated by the .dark class on <html>. Both themes must maintain WCAG 2.2 AA contrast."
    ]
  }
}
