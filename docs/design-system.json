  "guidelines": {
    "do": [
      "Use IBM Plex Sans and IBM Plex Mono exactly as the specimen shows",
      "Use blue as the primary action color and informational accent",
      "Reserve green, red, and amber for outcomes and risk semantics",
      "Keep corners compact at 4px unless the specimen explicitly uses 3px, 6px, or 28px",
      "Use solid fills and thin borders instead of gradient-heavy surfaces"
    ],
    "dont": [
      "Do not document purple as the primary brand color",
      "Do not introduce glassmorphism, blur-heavy panels, or gradient headlines into this design system",
      "Do not infer responsive rules from the Pen file; they are not documented there",
      "Do not describe this file as a variable-driven token source; it contains no variables"
    ],
    "implementationNotes": [
      "The Pen file documents exemplars rather than reusable component symbols.",
      "Where a light specimen omits a fill and visually reads as white, treat white as the effective surface color in implementation.",
      "Dark-mode specimens usually switch from #FFFFFF to #0C0C0E or #161618 depending on component depth."
    ]
  }
